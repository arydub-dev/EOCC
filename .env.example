# ──────────────────────────────────────────────────────────────
# Emergency Operations Command Center (EOCC) — environment config
# Copy to .env and set strong values. NEVER commit a real .env.
# ──────────────────────────────────────────────────────────────

# --- Database ---
POSTGRES_USER=eocc
# Use a long, random password. Example generator:  openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=eocc
# Full SQLAlchemy URL (overrides the parts above if set).
# For local non-docker dev with SQLite use: sqlite:///./eocc.db
DATABASE_URL=postgresql+psycopg://eocc:change-me-strong-db-password@db:5432/eocc

# --- Cryptographic secrets (REQUIRED, no defaults in production) ---
# SECRET_KEY: signs JWT access tokens.   Generate:  openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
# REFRESH_TOKEN_SECRET: keyed hash for refresh tokens (defaults to a derivation
# of SECRET_KEY if left blank).          Generate:  openssl rand -hex 32
REFRESH_TOKEN_SECRET=
# ENCRYPTION_KEY: Fernet key for field encryption (connector secrets, MFA seeds).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ALGORITHM=HS256

# --- Token lifetimes ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
REMEMBER_ME_EXPIRE_DAYS=30

# --- Session cookies (recommended for production behind TLS) ---
USE_AUTH_COOKIES=true
COOKIE_SECURE=true        # HTTPS-only cookies; set false only for local http dev
COOKIE_SAMESITE=lax

# --- Password policy ---
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true

# --- Account lockout / rate limiting ---
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=300
RATE_LIMIT_AUTH_PER_MINUTE=20

# --- Upload / request limits ---
MAX_REQUEST_BYTES=2000000
MAX_UPLOAD_BYTES=10000000
MAX_IMPORT_ROWS=50000

# --- App ---
ENVIRONMENT=production       # use 'development' locally
PROJECT_NAME=Emergency Operations Command Center
API_V1_PREFIX=/api/v1
# Comma-separated allowed origins. Behind the bundled proxy this is the site URL.
BACKEND_CORS_ORIGINS=http://localhost

# --- Seeding ---
SEED_ON_STARTUP=true
SEED_INCIDENTS=100
SEED_HOSPITALS=50
SEED_SHELTERS=200
SEED_RESOURCES=1000
SEED_UTILITY_OUTAGES=500
SEED_ALERTS=1000

# --- AI Copilot (optional) ---
# Leave blank to use the deterministic local fallback engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Edge / frontend ---
PROXY_PORT=80
# With the bundled reverse proxy, the API is same-origin under /api/v1.
NEXT_PUBLIC_API_BASE_URL=/api/v1
